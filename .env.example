# ============================================================
# WOLVERINE – THE NEURAL ENGINE (ENV CONFIG)
# Copy this to .env to customize your setup.
# ============================================================

# ── System Identity ─────────────────────────────────────────
WOLVERINE_NAME=Wolf
WOLVERINE_EMOJI=🐺

# ── Directories (Local Home Strategy) ───────────────────────
# Data is stored in your home directory (~/WolverineData) by default.
# Use these to override location (useful for Docker).
# WOLVERINE_HOME=/root/.wolverine
# WOLVERINE_WORKSPACE_DIR=/root/WolverineData/workspace

# ── API Gateway ─────────────────────────────────────────────
PORT=18789
NODE_ENV=development

# ── Intelligence Provider ───────────────────────────────────
# Options: ollama | openrouter | openai | anthropic
WOLVERINE_PROVIDER=ollama
WOLVERINE_MODEL=qwen3:4b

# ── Ollama Config ───────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# For remote Ollama instances, increase timeout (in milliseconds)
# OLLAMA_TIMEOUT=300000

# ── OpenRouter / External ───────────────────────────────────
# OPENROUTER_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# ── Telegram Bot (Optional) ─────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_ALLOWED_USER_ID=your_id

# ── Search Providers ────────────────────────────────────────
# TAVILY_API_KEY=your_key_here
# BRAVE_SEARCH_API_KEY=your_key_here
