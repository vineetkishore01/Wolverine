# ============================================================
# Wolverine - .gitignore
# ============================================================

# --- INTERNAL DEVELOPMENT DOCS (NEVER COMMIT) ---
WOLVERINE-BLUEPRINT.md
SECURITY-AUDIT.md
SECURITY-CHANGES.md
SELF-REPAIR.md
CHANGELOG.md

# --- RUNTIME DATA (NEVER COMMIT) ---
workspace/
.wolverine/config.json
.localclaw/
.smallclaw/

# Keep skeleton templates for new users
!.wolverine/skel/
!.smallclaw/skel/

# --- NODE ---
node_modules/
node_modules.nosync/
dist/
*.js.map
package/
*.tgz

# --- VENDOR LIBS ---
vendor_libs/

# --- TESTS ---
tests/

# --- LOGS ---
*.log
gateway.log
gateway.err.log
tmp_*.json
tmp_payload.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- SECRETS ---
.env

# --- BUILD/CACHE ARTIFACTS ---
.npm_cache/
.tmp-study/
